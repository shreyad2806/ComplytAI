# Existing n8n webhook configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/complyt-ai

# Required by CrewAI when agents are introduced.
# Use a real secret only in the ignored .env.local file.
OPENAI_API_KEY=

# CrewAI backend configuration
CREWAI_MODEL=gpt-4.1-mini
CREWAI_TEMPERATURE=0.1
CREWAI_MAX_DOCUMENT_CHARS=60000

# Pinecone report memory (optional until a Pinecone index is provisioned)
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=complyt-reports
PINECONE_TOP_K=3
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
